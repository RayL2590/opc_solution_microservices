# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Environment files with real secrets — never commit them (NFR-S3).
# The secret-free template ".env.example" stays tracked.
.env
*.env
!.env.example

# BMAD / Claude tooling and generated artifacts (not part of the project itself)
.claude/
_bmad/
_bmad-output/
