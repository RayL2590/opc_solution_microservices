# Environment variable surface for the medilabo microservices platform (NFR-S3).
# Copy this file to ".env", fill in the REAL values, and never commit ".env" — it is git-ignored.
# This template is the single source of truth for every secret/config the services consume.
# No real secret must ever appear in this file.

# --- patient-service / MySQL (consumed in Story 1.2) ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/patientdb?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=patientdb
SPRING_DATASOURCE_PASSWORD=change-me

# --- notes-service / MongoDB (documented now, consumed in Epic 3) ---
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/notesdb

# --- In-memory user store, same value across every service (pass-through auth D-SEC-3;
#     consumed in Stories 1.4 / 2.4 / 3.4 / 4.4 / 5.1) ---
MEDILABO_USER=medilabo
# BCrypt HASH only — never plaintext.
MEDILABO_PASSWORD_BCRYPT=$2a$10$replace-with-a-real-bcrypt-hash

# --- Gateway base URI for assessment-service & front-service RestClient (consumed in Epics 4/5) ---
GATEWAY_URI=http://localhost:8080
